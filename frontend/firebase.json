{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/admin", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/admin/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/content-manager/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/content-type-builder/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/upload", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/upload/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/i18n/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/users-permissions/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "/api/**", "run": { "serviceId": "ange-website-backend", "region": "europe-west1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
